# Copy to .env and fill in. APP_SECRET_KEY is required; generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=

POSTGRES_USER=deploycore
POSTGRES_PASSWORD=deploycore
POSTGRES_DB=deploycore
DATABASE_URL=postgresql+asyncpg://deploycore:deploycore@postgres:5432/deploycore

REDIS_URL=redis://redis:6379/0

# Public base URL guest VMs use to reach the callback endpoint (see ARCHITECTURE.md).
APP_PUBLIC_URL=http://localhost:8000

# Local storage paths (mounted volumes in docker-compose)
ISO_STORAGE_PATH=/data/isos
ISO_BUILD_TMP=/data/iso_build_tmp

