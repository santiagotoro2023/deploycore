# Copy to .env and fill in. APP_SECRET_KEY is required; generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=

POSTGRES_USER=deploycore
POSTGRES_PASSWORD=deploycore
POSTGRES_DB=deploycore
DATABASE_URL=postgresql+asyncpg://deploycore:deploycore@postgres:5432/deploycore

REDIS_URL=redis://redis:6379/0

# Public base URL guest VMs use to reach the callback endpoint and download
# app assets, plain http:// on port 8000, not the HTTPS proxy (see README
# "HTTPS certificate"). scripts/setup.sh auto-detects this host's LAN IP and
# fills it in for you if this is still left at the default below; edit it
# yourself if the auto-detected address is wrong (multiple NICs, VMs on a
# different network than the one setup.sh picked, etc.) or if you skip
# setup.sh and run docker compose directly.
APP_PUBLIC_URL=http://localhost:8000

# Local storage paths (mounted volumes in docker-compose)
ISO_STORAGE_PATH=/data/isos
ISO_BUILD_TMP=/data/iso_build_tmp

# --- Remote Management (self-hosted RustDesk stack) ---
# RUSTDESK_RELAY_HOST is the address managed agents and the browser use to
# reach the RustDesk rendezvous/relay servers - normally this host's own LAN
# IP or public hostname (the SAME reachable address as APP_PUBLIC_URL, just
# without the scheme/port). Agents can be anywhere, so this must NOT be
# localhost/127.0.0.1 in a real deployment.
RUSTDESK_RELAY_HOST=localhost
# A random secret shared between the hbbs server and the api server for JWT
# verification. Generate one with: python -c "import secrets;print(secrets.token_hex(32))"
RUSTDESK_JWT_KEY=
# The DeployCore backend logs into the rustdesk-api server as this service
# account to mint per-session share links. Set the password to the admin
# account's password in the rustdesk stack (default admin username is "admin";
# on first run the rustdesk-api server prints a generated admin password to its
# container logs unless you set one). These map to the backend's
# RUSTDESK_ADMIN_USERNAME / RUSTDESK_ADMIN_PASSWORD settings.
RUSTDESK_ADMIN_USERNAME=admin
RUSTDESK_ADMIN_PASSWORD=
# Internal (compose-network) URL the DeployCore API uses to reach rustdesk-api,
# and the public URL the operator's browser loads the embedded web client from.
# The public one must be reachable from the browser (not the docker-internal
# hostname) - typically http(s)://<this host>:21114.
RUSTDESK_API_INTERNAL_URL=http://rustdesk:21114
RUSTDESK_API_PUBLIC_URL=http://localhost:21114
# On startup DeployCore auto-fetches the agent .msi from here (built+published
# by .github/workflows/build-agent-msi.yml) and registers it as the global
# "Remote Agent" App Asset. Leave the default unless you forked the repo; set
# it empty to disable auto-fetch (air-gapped installs upload the .msi by hand).
REMOTE_AGENT_MSI_URL=https://github.com/santiagotoro2023/deploycore/releases/download/agent-latest/DeployCoreRemoteAgent.msi

# Self-update (Settings -> Updates) normally needs no configuration at all,
# the updater container figures out this repo's own path on the host by
# itself. Only set this if that automatic discovery can't work in your
# Docker setup (e.g. a socket proxy that blocks `docker inspect`): the
# absolute path to this repo on the host, e.g. /home/you/deploycore.
# PROJECT_DIR=

