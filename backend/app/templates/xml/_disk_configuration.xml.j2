{% set extra_volumes = disk_layout.layout_json.extra_volumes or [] %}
{% set os_volume = disk_layout.layout_json.os_volume %}
<Disk wcm:action="add">
    <DiskID>0</DiskID>
    <WillWipeDisk>true</WillWipeDisk>
    <CreatePartitions>
        <CreatePartition wcm:action="add">
            <Order>1</Order>
            <Type>EFI</Type>
            <Size>{{ disk_layout.layout_json.efi_size_mb }}</Size>
        </CreatePartition>
        <CreatePartition wcm:action="add">
            <Order>2</Order>
            <Type>MSR</Type>
            <Size>{{ disk_layout.layout_json.msr_size_mb }}</Size>
        </CreatePartition>
        <CreatePartition wcm:action="add">
            <Order>3</Order>
            <Type>Primary</Type>
{% if os_volume == "remaining" %}
            <Extend>true</Extend>
{% else %}
            <Size>{{ os_volume.size_mb }}</Size>
{% endif %}
        </CreatePartition>
{% for volume in extra_volumes %}
        <CreatePartition wcm:action="add">
            <Order>{{ loop.index + 3 }}</Order>
            <Type>Primary</Type>
            <Size>{{ volume.size_mb }}</Size>
        </CreatePartition>
{% endfor %}
    </CreatePartitions>
    <ModifyPartitions>
        <ModifyPartition wcm:action="add">
            <Order>1</Order>
            <PartitionID>1</PartitionID>
            <Format>FAT32</Format>
            <Label>System</Label>
        </ModifyPartition>
        <ModifyPartition wcm:action="add">
            <Order>2</Order>
            <PartitionID>2</PartitionID>
        </ModifyPartition>
        <ModifyPartition wcm:action="add">
            <Order>3</Order>
            <PartitionID>3</PartitionID>
            <Format>NTFS</Format>
            <Label>Windows</Label>
            <Letter>C</Letter>
        </ModifyPartition>
{% for volume in extra_volumes %}
        <ModifyPartition wcm:action="add">
            <Order>{{ loop.index + 3 }}</Order>
            <PartitionID>{{ loop.index + 3 }}</PartitionID>
            <Format>NTFS</Format>
            <Label>{{ volume.label }}</Label>
            <Letter>{{ volume.drive_letter }}</Letter>
        </ModifyPartition>
{% endfor %}
    </ModifyPartitions>
</Disk>
