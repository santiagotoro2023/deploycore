{% set extra_volumes = disk_layout.layout_json.extra_volumes or [] %}
{% set os_volume = disk_layout.layout_json.os_volume %}
{% set recovery_size_mb = disk_layout.layout_json.recovery_size_mb %}
{% set os_partition_number = 4 if recovery_size_mb else 3 %}
<Disk wcm:action="add">
    <DiskID>0</DiskID>
    <WillWipeDisk>true</WillWipeDisk>
    <CreatePartitions>
        <CreatePartition wcm:action="add">
            <Order>1</Order>
            <Type>EFI</Type>
            <Size>{{ disk_layout.layout_json.efi_size_mb }}</Size>
        </CreatePartition>
        <CreatePartition wcm:action="add">
            <Order>2</Order>
            <Type>MSR</Type>
            <Size>{{ disk_layout.layout_json.msr_size_mb }}</Size>
        </CreatePartition>
{% if recovery_size_mb %}
        <CreatePartition wcm:action="add">
            <Order>3</Order>
            <Type>Primary</Type>
            <Size>{{ recovery_size_mb }}</Size>
        </CreatePartition>
{% endif %}
        <CreatePartition wcm:action="add">
            <Order>{{ os_partition_number }}</Order>
            <Type>Primary</Type>
{% if os_volume == "remaining" %}
            <Extend>true</Extend>
{% else %}
            <Size>{{ os_volume.size_mb }}</Size>
{% endif %}
        </CreatePartition>
{% for volume in extra_volumes %}
        <CreatePartition wcm:action="add">
            <Order>{{ os_partition_number + loop.index }}</Order>
            <Type>Primary</Type>
            <Size>{{ volume.size_mb }}</Size>
        </CreatePartition>
{% endfor %}
    </CreatePartitions>
    <ModifyPartitions>
        <ModifyPartition wcm:action="add">
            <Order>1</Order>
            <PartitionID>1</PartitionID>
            <Format>FAT32</Format>
            <Label>System</Label>
        </ModifyPartition>
        <ModifyPartition wcm:action="add">
            <Order>2</Order>
            <PartitionID>2</PartitionID>
        </ModifyPartition>
{% if recovery_size_mb %}
        {# A CreatePartition with no matching ModifyPartition at all made
           Setup abandon unattended mode and drop to the interactive
           "choose install location" screen (confirmed on a real
           deployment) - every created partition needs an acknowledgment
           entry, same as MSR above. So this stays, minimal: no
           Format/Label/TypeID, matching the MSR pattern, so the partition
           is still functionally raw (no filesystem, no type change) for
           the post-install "Recovery partition relocation" script to
           format and type after Windows is fully installed - see that
           script in setup.py's DEFAULT_DISK_LAYOUT_POST_INSTALL_SCRIPTS
           for why formatting/typing it during Setup itself, before
           Windows exists on the disk, isn't safe to do here instead. #}
        <ModifyPartition wcm:action="add">
            <Order>3</Order>
            <PartitionID>3</PartitionID>
        </ModifyPartition>
{% endif %}
        <ModifyPartition wcm:action="add">
            <Order>{{ os_partition_number }}</Order>
            <PartitionID>{{ os_partition_number }}</PartitionID>
            <Format>NTFS</Format>
            <Label>Windows</Label>
            <Letter>C</Letter>
        </ModifyPartition>
{% for volume in extra_volumes %}
        <ModifyPartition wcm:action="add">
            <Order>{{ os_partition_number + loop.index }}</Order>
            <PartitionID>{{ os_partition_number + loop.index }}</PartitionID>
            <Format>NTFS</Format>
            <Label>{{ volume.label }}</Label>
            <Letter>{{ volume.drive_letter }}</Letter>
        </ModifyPartition>
{% endfor %}
    </ModifyPartitions>
</Disk>
