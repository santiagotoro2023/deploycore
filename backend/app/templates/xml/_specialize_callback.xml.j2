<RunSynchronousCommand wcm:action="add">
    <Description>Notify DeployCore that OS install is complete</Description>
    <Order>4</Order>
    <Path>curl.exe -X POST "{{ callback_base_url }}/api/callback/{{ deployment.callback_token }}" --max-time 15 --retry 3 --retry-delay 5 --silent --show-error -o NUL</Path>
</RunSynchronousCommand>
